APP_ENV=local
DJANGO_SETTINGS_MODULE=config.settings.local
DJANGO_SECRET_KEY=change-me
DEBUG=true
ALLOWED_HOSTS=localhost,127.0.0.1,api-gateway
PORT=8000
LOG_LEVEL=INFO
API_GATEWAY_USE_POSTGRES=false
POSTGRES_DB=api_gateway
POSTGRES_USER=api_gateway
POSTGRES_PASSWORD=api_gateway
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
CORS_ALLOWED_ORIGINS=http://localhost:4200,http://127.0.0.1:4200,http://localhost:4300,http://127.0.0.1:4300
JWT_ISSUER=https://identity.aerolytic.local
JWT_AUDIENCE=aerolytic-clients
JWT_JWKS_URL=http://127.0.0.1:8001/api/v1/auth/jwks/
IDENTITY_SERVICE_BASE_URL=http://127.0.0.1:8001
CRM_SERVICE_BASE_URL=http://127.0.0.1:8002
WORKFLOW_SERVICE_BASE_URL=http://127.0.0.1:8003
REQUEST_TIMEOUT_SECONDS=10